NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-for-admin-api-only

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: enables Tushare historical/basic data enhancement.
TUSHARE_TOKEN=

# Comma-separated site owner/admin emails that can view /settings.
ADMIN_EMAILS=owner@example.com

# Optional local-only fallback when Supabase is not configured.
LOCAL_ADMIN_EMAIL=owner@example.com
